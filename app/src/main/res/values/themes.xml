<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.AppointmentScheduler" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@color/ios_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorPrimary">@color/ios_accent</item>
        <item name="colorPrimaryVariant">@color/ios_accent</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#4B4B66</item>
        <item name="colorSecondaryVariant">#2c2c3e</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="colorSurface">@color/ios_elevated</item>
        <item name="colorOnBackground">@color/ios_bg</item>
        <item name="colorError">#E84141</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="colorOnError">#FFFFFF</item>
        <item name="android:navigationBarColor">@color/ios_tab_bar</item>

    </style>


    <style name="Theme.AppointmentScheduler" parent="Base.Theme.AppointmentScheduler" />

    <!-- Transparent sheet surface so custom rounded background shows (no gray panel). -->
    <style name="ThemeOverlay.App.BottomSheetDialog" parent="ThemeOverlay.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.App.BottomSheet.Modal</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <style name="Widget.App.BottomSheet.Modal" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.App.BottomSheet</item>
    </style>

    <style name="ShapeAppearance.App.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

</resources>