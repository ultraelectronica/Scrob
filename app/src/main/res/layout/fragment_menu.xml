<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_screen_gradient">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Menu"
        android:textSize="34sp"
        android:fontFamily="@font/inter_semibold"
        android:letterSpacing="-0.02"
        android:textColor="@color/ios_label_primary"
        android:paddingTop="48dp"
        android:paddingHorizontal="20dp"
        android:paddingBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/text_menu"
        android:textSize="16sp"
        android:fontFamily="@font/inter_regular"
        android:textColor="@color/ios_label_secondary"
        android:paddingHorizontal="20dp"
        android:paddingBottom="32dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="12dp"
        android:text="Settings"
        android:fontFamily="@font/inter_semibold"
        android:textColor="@color/ios_label_primary"
        android:padding="16dp"
        app:backgroundTint="@color/ios_elevated"
        app:strokeWidth="0.5dp"
        app:strokeColor="@color/ios_separator"
        app:cornerRadius="14dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_help"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:text="Help"
        android:fontFamily="@font/inter_semibold"
        android:textColor="@color/ios_label_primary"
        android:padding="16dp"
        app:backgroundTint="@color/ios_elevated"
        app:strokeWidth="0.5dp"
        app:strokeColor="@color/ios_separator"
        app:cornerRadius="14dp" />

</LinearLayout>