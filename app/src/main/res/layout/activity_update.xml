<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_update"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:navigationIcon="@drawable/ic_chevron_left_ios"
            app:navigationIconTint="@color/ios_label_primary"
            app:title="@string/appointment_detail_title"
            app:titleTextColor="@color/ios_label_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="32dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="8dp">

            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_ios_view_accent_line"
                android:importantForAccessibility="no" />

            <TextView
                style="@style/HomeSectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/appointment_detail_section" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/ios_elevated"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/ios_separator"
                app:strokeWidth="0.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_semibold"
                        android:letterSpacing="0.06"
                        android:text="@string/appointment_field_title"
                        android:textAllCaps="true"
                        android:textColor="@color/ios_label_tertiary"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/nameSet2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_sheet_input_field"
                        android:fontFamily="@font/inter_regular"
                        android:hint="@string/appointment_hint_title"
                        android:inputType="textCapSentences"
                        android:minHeight="52dp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="14dp"
                        android:textColor="@color/ios_label_primary"
                        android:textColorHint="@color/ios_label_tertiary"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:fontFamily="@font/inter_semibold"
                        android:letterSpacing="0.06"
                        android:text="@string/appointment_field_description"
                        android:textAllCaps="true"
                        android:textColor="@color/ios_label_tertiary"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/descriptionSet2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_sheet_input_field"
                        android:fontFamily="@font/inter_regular"
                        android:gravity="top|start"
                        android:hint="@string/appointment_hint_description"
                        android:inputType="textMultiLine|textCapSentences"
                        android:minLines="3"
                        android:paddingHorizontal="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:textColor="@color/ios_label_primary"
                        android:textColorHint="@color/ios_label_tertiary"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:fontFamily="@font/inter_semibold"
                        android:letterSpacing="0.06"
                        android:text="@string/appointment_field_date_time"
                        android:textAllCaps="true"
                        android:textColor="@color/ios_label_tertiary"
                        android:textSize="11sp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:cardBackgroundColor="@color/ios_surface_secondary"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/ios_separator"
                        app:strokeWidth="0.5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="10dp">

                            <TextView
                                android:id="@+id/dateText2"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/inter_semibold"
                                android:hint="@string/appointment_hint_date"
                                android:textColor="@color/ios_label_primary"
                                android:textColorHint="@color/ios_label_tertiary"
                                android:textSize="16sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/datePicker2"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_semibold"
                                android:text="@string/appointment_pick"
                                android:textColor="@color/ios_accent" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:cardBackgroundColor="@color/ios_surface_secondary"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/ios_separator"
                        app:strokeWidth="0.5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="10dp">

                            <TextView
                                android:id="@+id/timeText2"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/inter_semibold"
                                android:hint="@string/appointment_hint_time"
                                android:textColor="@color/ios_label_primary"
                                android:textColorHint="@color/ios_label_tertiary"
                                android:textSize="16sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/timePicker2"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_semibold"
                                android:text="@string/appointment_pick"
                                android:textColor="@color/ios_accent" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:fontFamily="@font/inter_semibold"
                        android:letterSpacing="0.06"
                        android:text="@string/appointment_field_link"
                        android:textAllCaps="true"
                        android:textColor="@color/ios_label_tertiary"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/linkSet2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_sheet_input_field"
                        android:fontFamily="@font/inter_regular"
                        android:hint="@string/appointment_hint_link"
                        android:inputType="textUri"
                        android:minHeight="52dp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="14dp"
                        android:textColor="@color/ios_label_primary"
                        android:textColorHint="@color/ios_label_tertiary"
                        android:textSize="16sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_semibold"
                                android:text="@string/appointment_edit_label"
                                android:textColor="@color/ios_label_primary"
                                android:textSize="16sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/inter_regular"
                                android:text="@string/appointment_edit_sub"
                                android:textColor="@color/ios_label_tertiary"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/edit_toggle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:thumbTint="@color/ios_accent"
                            app:trackTint="@color/ios_surface_tertiary" />
                    </LinearLayout>

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/checkFinish"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="@string/appointment_mark_finished"
                        android:textColor="@color/ios_label_primary"
                        app:buttonTint="@color/ios_accent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/saveEditSchedButton"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:fontFamily="@font/inter_semibold"
                        android:text="@string/appointment_save"
                        android:textAllCaps="false"
                        android:visibility="gone"
                        app:backgroundTint="@color/ios_accent"
                        app:cornerRadius="14dp"
                        tools:visibility="visible" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
