<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_surface"
    android:clipToOutline="true"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="10dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_sheet_drag_handle"
            android:importantForAccessibility="no" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter_extrabold"
            android:letterSpacing="-0.02"
            android:text="New appointment"
            android:textColor="@color/white"
            android:textSize="26sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="22dp"
            android:fontFamily="@font/inter_medium"
            android:text="Fill in the details below. Link is optional."
            android:textColor="#8F8F99"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/inter_semibold"
            android:letterSpacing="0.06"
            android:text="Title"
            android:textAllCaps="true"
            android:textColor="#6B6B78"
            android:textSize="11sp" />

        <EditText
            android:id="@+id/nameSet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_sheet_input_field"
            android:fontFamily="@font/inter_regular"
            android:hint="e.g. Team sync"
            android:inputType="textCapSentences"
            android:minHeight="52dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:textColor="@color/white"
            android:textColorHint="#555566"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/inter_semibold"
            android:letterSpacing="0.06"
            android:text="Description"
            android:textAllCaps="true"
            android:textColor="#6B6B78"
            android:textSize="11sp" />

        <EditText
            android:id="@+id/descriptionSet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_sheet_input_field"
            android:fontFamily="@font/inter_regular"
            android:gravity="top|start"
            android:hint="What is this meeting about?"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="3"
            android:paddingHorizontal="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:textColor="@color/white"
            android:textColorHint="#555566"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/inter_semibold"
            android:letterSpacing="0.06"
            android:text="Date &amp; time"
            android:textAllCaps="true"
            android:textColor="#6B6B78"
            android:textSize="11sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#16161F"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#1F1F2E"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp">

                <TextView
                    android:id="@+id/dateText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/inter_medium"
                    android:gravity="center_vertical"
                    android:hint="YYYY-MM-DD"
                    android:minHeight="44dp"
                    android:textColor="@color/white"
                    android:textColorHint="#555566"
                    android:textSize="15sp"
                    tools:text="2026-04-20" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/datePicker"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:fontFamily="@font/inter_semibold"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:paddingHorizontal="16dp"
                    android:text="Pick"
                    android:textAllCaps="false"
                    android:textColor="#2952E3"
                    android:textSize="13sp"
                    app:cornerRadius="12dp"
                    app:rippleColor="#332952E3"
                    app:strokeColor="#2952E3"
                    app:strokeWidth="1dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            app:cardBackgroundColor="#16161F"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#1F1F2E"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp">

                <TextView
                    android:id="@+id/timeText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/inter_medium"
                    android:gravity="center_vertical"
                    android:hint="HH:MM AM/PM"
                    android:minHeight="44dp"
                    android:textColor="@color/white"
                    android:textColorHint="#555566"
                    android:textSize="15sp"
                    tools:text="2:30 PM" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/timePicker"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:fontFamily="@font/inter_semibold"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:paddingHorizontal="16dp"
                    android:text="Pick"
                    android:textAllCaps="false"
                    android:textColor="#2952E3"
                    android:textSize="13sp"
                    app:cornerRadius="12dp"
                    app:rippleColor="#332952E3"
                    app:strokeColor="#2952E3"
                    app:strokeWidth="1dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/inter_semibold"
            android:letterSpacing="0.06"
            android:text="Meeting link"
            android:textAllCaps="true"
            android:textColor="#6B6B78"
            android:textSize="11sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/inter_medium"
            android:text="Optional — paste a URL for video calls or docs."
            android:textColor="#8F8F99"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/linkSet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="22dp"
            android:background="@drawable/bg_sheet_input_field"
            android:fontFamily="@font/inter_regular"
            android:hint="https://…"
            android:inputType="textUri"
            android:minHeight="52dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:textColor="@color/white"
            android:textColorHint="#555566"
            android:textSize="15sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/submitSchedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:fontFamily="@font/inter_semibold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Save appointment"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:backgroundTint="#2952E3"
            app:cornerRadius="14dp"
            app:elevation="4dp"
            app:rippleColor="#66FFFFFF" />
    </LinearLayout>
</ScrollView>
