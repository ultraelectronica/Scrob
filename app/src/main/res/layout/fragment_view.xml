<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View Appointments"
            android:textSize="34sp"
            android:fontFamily="@font/inter_semibold"
            android:letterSpacing="-0.02"
            android:textColor="@color/ios_label_primary"
            android:paddingTop="48dp"
            android:paddingHorizontal="20dp"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/text_view"
            android:textSize="16sp"
            android:fontFamily="@font/inter_regular"
            android:textColor="@color/ios_label_secondary"
            android:paddingHorizontal="20dp"
            android:paddingBottom="16dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/list_appointments"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="16dp"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="88dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/empty_text"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="No appointments scheduled.\nTap + to add your first appointment."
        android:textSize="16sp"
        android:fontFamily="@font/inter_regular"
        android:textColor="@color/ios_label_secondary"
        android:visibility="gone"
        android:paddingHorizontal="20dp"
        android:layout_marginTop="120dp" />

</FrameLayout>